# API Configuration
API_PREFIX=/api
AUTH_TOKEN=demo-token-for-hackathon
CORS_ORIGINS=http://localhost:4200

# Database Configuration
DATABASE_URL=postgresql+asyncpg://aigp:aigp_password@localhost:5432/aigp_db
REDIS_URL=redis://localhost:6379

# Vector Database Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=aigp_regulations

# Ollama (local open-source LLM — runs in Docker, no auth required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000
LLM_MAX_RETRIES=2
LLM_REQUEST_TIMEOUT_SECONDS=120

# Embedding / Classification model (local sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Proxy
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# Application
LOG_LEVEL=INFO
